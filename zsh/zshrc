# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Case-insensitive and completion configurations
unsetopt BEEP

# Which plugins would you like to load?
plugins=(git)

# Initialize the Oh My Zsh base framework
source $ZSH/oh-my-zsh.sh

# User Configuration & Core Environment Settings
unsetopt BEEP

# Active Shell Integrations & Extensions
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
if which rbenv > /dev/null; then eval "$(rbenv init -)"; fi

# Java Development Environment — LTS 21
export JAVA_HOME=$(/usr/libexec/java_home -v 21)
export PATH="$JAVA_HOME/bin:$PATH"

# Global System Binary Mapping
export PATH="/opt/homebrew/opt/sqlite/bin:$PATH"
export PATH="/Applications/IntelliJ IDEA CE.app/Contents/MacOS:$PATH"
eval "$(/opt/homebrew/bin/brew shellenv)"

# System Toolchains & Engine Paths
export PATH="/Users/raj/.antigravity/antigravity/bin:$PATH"
export PATH="/Users/raj/.antigravity-ide/antigravity-ide/bin:$PATH"

# Custom Utilities & System Global Aliases
alias idea='open -a "IntelliJ IDEA.app"'

# bro - Multi-Language Tooling & System Modernization Macro Engine
bro() {
  case "$1" in
    espresso)
      echo "=== macOS Software Update ==="
      softwareupdate -ia --verbose

      echo "\n=== Homebrew ==="
      brew update && brew upgrade && brew upgrade --cask --greedy && brew cleanup

      echo "\n=== Mac App Store (skipping Xcode) ==="
      mas outdated | grep -v "497799835" | awk '{print $1}' | xargs -r mas upgrade

      echo "\n=== npm global packages ==="
      npm update -g 2>/dev/null || echo "npm not found, skipping"

      echo "\n=== pip packages ==="
      pip3 install --upgrade pip 2>/dev/null || echo "pip3 not found, skipping"

      echo "\nAll updates complete!"
      ;;
    *)
      echo "Unknown command: bro $1"
      ;;
  esac
}

# Source Local Background Execution Protocols
. "$HOME/.local/bin/env"
source "$HOME/.local/bin/env"

# Initialize Compiled Rust Starship Prompt Engine Layout
eval "$(starship init zsh)"
